  "grammar_basics": {
    "word_order": {
      "pattern": "SOV (Subject-Object-Verb)",
      "description": "Tigrinya follows Subject-Object-Verb word order, unlike many Semitic languages. The verb comes at the end of the sentence.",
      "examples": [
        {
          "geez": "ኣነ ማይ ሰቲየ",
          "transliteration": "ane may setiye",
          "literal": "I water drank",
          "english": "I drank water"
        },
        {
          "geez": "ንሱ መጽሓፍ ኣንቢቡ",
          "transliteration": "nsu mets'haf anbibu",
          "literal": "He book read",
          "english": "He read a book"
        }
      ]
    },

    "noun_gender": {
      "description": "Tigrinya has two grammatical genders: masculine and feminine. The gender of animate nouns generally follows natural gender. For inanimate nouns, gender is often not predictable from form or meaning and must be learned.",
      "rules": [
        "Most nouns ending in a consonant tend to be masculine",
        "Some nouns ending in '-ti' or '-t' tend to be feminine",
        "Adjectives agree with the noun in gender and number (masculine, feminine, plural forms)",
        "The gender of inanimate nouns is largely arbitrary and must be memorized"
      ],
      "examples": [
        { "geez": "ዓቢ ሰብ", "transliteration": "'abi seb", "english": "big person (masc.)" },
        { "geez": "ዓባይ ሰበይቲ", "transliteration": "'abay sebeyti", "english": "big woman (fem.)" }
      ]
    },

