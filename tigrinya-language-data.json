  "writing_system": {
    "name": "Ge'ez / Fidel",
    "description": "The Ge'ez script (ፊደል, Fidel) is an abugida. Each base character represents a consonant, and vowel sounds are indicated by systematic modifications to the base form. This makes it a syllabary where each symbol represents a consonant+vowel syllable.",
    "structure": {
      "total_base_consonants": 32,
      "vowel_orders": 7,
      "description": "Each consonant has 7 forms (called 'orders'), one for each vowel. The forms are created by adding small strokes, loops, or modifications to the base consonant character."
    },
    "seven_orders": [
      {
        "order": 1,
        "vowel": "e/ä",
        "ipa": "/ə/ or /æ/",
        "description": "Base form (default vowel, a central vowel like 'uh')"
      },
      {
        "order": 2,
        "vowel": "u",
        "ipa": "/u/",
        "description": "Usually adds a stroke to the right of the base"
      },
      {
        "order": 3,
        "vowel": "i",
        "ipa": "/i/",
        "description": "Usually adds a stroke below the base"
      },
      {
        "order": 4,
        "vowel": "a",
        "ipa": "/a/",
        "description": "Usually adds a stroke to the right-bottom"
      },
      {
        "order": 5,
        "vowel": "ie/e",
        "ipa": "/e/",
        "description": "Usually modifies the bottom of the character"
      },
      {
        "order": 6,
        "vowel": "i/ə (reduced)",
        "ipa": "/ɨ/ or silent",
        "description": "Represents consonant alone or with minimal vowel; used for consonant clusters"
      },
      {
        "order": 7,
        "vowel": "o",
        "ipa": "/o/",
        "description": "Usually adds a stroke to the upper right"
      }
    ],
    "h_series_example": {
      "description": "The first row of the Fidel chart demonstrates how the 7 orders work using the consonant 'h' (ሀ series). All forms share the same base U-shape but are modified for each vowel.",
      "forms": [
        { "order": 1, "geez": "ሀ", "transliteration": "he/hä", "vowel": "ä" },
        { "order": 2, "geez": "ሁ", "transliteration": "hu", "vowel": "u" },
