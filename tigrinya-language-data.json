    "verb_conjugation": {
      "description": "Tigrinya verbs are built from consonantal roots (usually 3 consonants). Verb forms are created by adding vowel patterns, prefixes, and suffixes to these roots. Verbs agree with their subject in person, number, and gender.",
      "root_system": {
        "description": "Most verb roots consist of 3 consonants. Example: the root {s-b-r} means 'break'. The citation form (perfect 3rd masc. sg.) is ሰበረ (säbärä).",
        "example_root": "s-b-r (break)"
      },
      "tense_system": {
        "perfect": {
          "description": "Used for past/completed actions. Formed by adding SUFFIXES to the verb stem.",
          "example_verb": "ሰበረ (säbärä) - 'he broke' (citation form)",
          "suffix_pattern": [
            { "person": "I", "suffix": "-ku", "example": "ሰቢረ-ኩ (sebire-ku)", "english": "I broke" },
